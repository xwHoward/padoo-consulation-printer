{
  "name": "consultation-printer-extension",
  "version": "1.0.0",
  "description": "浏览器插件 - 侧边栏信息抓取工具",
  "scripts": {
    "dev": "vite",
    "dev:extension": "node scripts/dev-setup.js && vite",
    "build": "vite build && node scripts/copy-files.js",
    "icons": "node scripts/generate-icons.js",
    "setup": "npm run icons && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@cloudbase/js-sdk": "^3.4.6",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.6.0",
    "less": "^4.1.3",
    "vite": "^4.5.0"
  }
}
