{
  "manifest_version": 2,
  "name": "Consultation Printer [DEV]",
  "version": "1.0.0",
  "description": "侧边栏信息抓取工具 (开发模式 - HMR 热更新)",
  "author": "ConsultationPrinter",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "consultation-printer@example.com",
      "strict_min_version": "78.0"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-loader.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    "assets/*",
    "chunks/*"
  ]
}
