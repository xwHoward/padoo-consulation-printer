<view class="checkbox-group">
  <label wx:for="{{oils}}" wx:key="_id" class="checkbox-item {{selectedOil === item._id ? 'selected' : ''}}" bindtap="onOilTap" data-oil="{{item._id}}">
    <view class="oil-checkbox"></view>
    <view class="oil-name">{{lang === 'en' && item.nameEn ? item.nameEn : item.name}}</view>
    <view class="oil-effect">{{lang === 'en' && item.effectEn ? item.effectEn : item.effect}}</view>
  </label>
</view>