<view class="project-list">
  <!-- 顶部横幅 -->
  <view class="header-banner">
    <view class="banner-overlay"></view>
    <view class="banner-content">
      <view class="banner-left">
        <view class="banner-title">PRICE LIST</view>
      </view>
      <view class="banner-right">
        <view class="banner-brand">PADOО · 趴岛</view>
        <view class="banner-type">SPA & MASSAGE</view>
      </view>
    </view>
    <!-- 语言切换 -->
    <view class="lang-toggle" bindtap="toggleLang">
      <text class="lang-toggle-text">{{t.lang}}</text>
    </view>
  </view>
  <!-- 项目列表 -->
  <scroll-view class="content" scroll-y>
    <view class="category-section" wx:for="{{groupedProjects}}" wx:key="categoryId">
      <!-- 分类标题栏 -->
      <view class="category-header">
        <text class="category-title">{{item.categoryName}}</text>
      </view>
      <!-- 列表表头 -->
      <view class="list-header">
        <view class="list-header-left">
          <text class="col-label-blank"></text>
        </view>
        <view class="list-header-right">
          <text class="col-label-time">{{t.colTime}}</text>
          <text class="col-label-price">{{t.colPrice}}</text>
        </view>
      </view>
      <view class="list-header-divider"></view>
      <!-- 项目行 -->
      <view class="project-row" wx:for="{{item.projects}}" wx:key="_id" wx:for-item="project">
        <view class="project-info">
          <view class="project-name">{{t.lang === '中' ? project.nameEn : project.subtitle}}</view>
          <view class="project-desc" wx:if="{{t.lang === 'EN'&&project.serviceFlow}}">{{project.serviceFlow}}</view>
          <view class="project-desc" wx:if="{{t.lang === '中'}}">{{project.name}}</view>
        </view>
        <view class="project-time-col">
          <text class="time-value">{{project.duration}} Min</text>
        </view>
        <view class="project-price-col">
          <text class="price-value">{{project.price}} RMB</text>
        </view>
      </view>
    </view>
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{groupedProjects.length === 0 && !loading}}">
      <text class="empty-text">{{t.emptyData}}</text>
    </view>
  </scroll-view>
  <!-- 加载遮罩 -->
  <view class="loading-mask" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">{{t.loading}}</text>
  </view>
</view>