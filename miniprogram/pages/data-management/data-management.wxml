<view class="data-management">
  <view class="tabs">
    <view class="tab-item {{activeTab === 'projects' ? 'active' : ''}}" data-value="projects" bindtap="onTabChange">
      项目管理
    </view>
    <view class="tab-item {{activeTab === 'categories' ? 'active' : ''}}" data-value="categories" bindtap="onTabChange">
      分类管理
    </view>
    <view class="tab-item {{activeTab === 'rooms' ? 'active' : ''}}" data-value="rooms" bindtap="onTabChange">
      房间管理
    </view>
    <view class="tab-item {{activeTab === 'oils' ? 'active' : ''}}" data-value="oils" bindtap="onTabChange">
      精油管理
    </view>
    <view class="tab-item {{activeTab === 'lottery' ? 'active' : ''}}" data-value="lottery" bindtap="onTabChange">
      抽奖奖品
    </view>
  </view>

  <view class="content">
    <!-- ==================== 项目管理 ==================== -->
    <view wx:if="{{activeTab === 'projects'}}" class="section">
      <view class="section-header">
        <view class="section-title">项目列表</view>
        <view class="add-btn" bindtap="onAddProject">添加项目</view>
      </view>
      <view class="list">
        <view class="list-item {{item.status === 'disabled' ? 'disabled' : ''}}" wx:for="{{projectsWithCategory}}" wx:key="_id">
          <view class="item-info">
            <view class="item-name-row">
              <view class="item-name">{{item.name}}</view>
              <view class="item-category-tag" wx:if="{{item.categoryId}}">{{item.categoryName}}</view>
            </view>
            <view class="item-subtitle" wx:if="{{item.subtitle}}">{{item.subtitle}}</view>
            <view class="item-details">
              <view class="item-detail">{{item.duration}}分钟</view>
              <view class="item-detail" wx:if="{{item.price}}">¥{{item.price}}</view>
              <view class="item-detail">{{item.commission}}元提成</view>
              <view class="item-tag" wx:if="{{item.isEssentialOilOnly}}">专用精油</view>
            </view>
          </view>
          <view class="item-actions">
            <view class="action-btn status-btn {{item.status === 'normal' ? 'status-normal' : 'status-disabled'}}" data-index="{{index}}" bindtap="handleToggleStatus">
              {{item.status === 'normal' ? '禁用' : '启用'}}
            </view>
            <view class="action-btn edit-btn" data-type="project" data-index="{{index}}" bindtap="openEditModal">编辑</view>
            <view class="action-btn delete-btn" data-index="{{index}}" bindtap="handleDelete">删除</view>
          </view>
        </view>
        <view class="empty" wx:if="{{projects.length === 0}}">
          <view>暂无项目数据</view>
        </view>
      </view>
    </view>

    <!-- ==================== 分类管理 ==================== -->
    <view wx:if="{{activeTab === 'categories'}}" class="section">
      <view class="section-header">
        <view class="section-title">分类列表</view>
        <view class="add-btn" bindtap="onAddCategory">添加分类</view>
      </view>
      <view class="list">
        <view class="list-item {{item.status === 'disabled' ? 'disabled' : ''}}" wx:for="{{projectCategories}}" wx:key="_id">
          <view class="item-info">
            <view class="item-name-row">
              <view class="item-name">{{item.name}}</view>
              <view class="item-detail">排序：{{item.order}}</view>
            </view>
          </view>
          <view class="item-actions">
            <view class="action-btn status-btn {{item.status === 'normal' ? 'status-normal' : 'status-disabled'}}" data-index="{{index}}" bindtap="handleToggleStatus">
              {{item.status === 'normal' ? '禁用' : '启用'}}
            </view>
            <view class="action-btn edit-btn" data-type="category" data-index="{{index}}" bindtap="openEditModal">编辑</view>
            <view class="action-btn delete-btn" data-index="{{index}}" bindtap="handleDelete">删除</view>
          </view>
        </view>
        <view class="empty" wx:if="{{projectCategories.length === 0}}">
          <view>暂无分类数据</view>
        </view>
      </view>
    </view>

    <!-- ==================== 房间管理 ==================== -->
    <view wx:if="{{activeTab === 'rooms'}}" class="section">
      <view class="section-header">
        <view class="section-title">房间列表</view>
        <view class="add-btn" bindtap="onAddRoom">添加房间</view>
      </view>
      <view class="list">
        <view class="list-item {{item.status === 'disabled' ? 'disabled' : ''}}" wx:for="{{rooms}}" wx:key="_id">
          <view class="item-info">
            <view class="item-name">{{item.name}}</view>
          </view>
          <view class="item-actions">
            <view class="action-btn status-btn {{item.status === 'normal' ? 'status-normal' : 'status-disabled'}}" data-index="{{index}}" bindtap="handleToggleStatus">
              {{item.status === 'normal' ? '禁用' : '启用'}}
            </view>
            <view class="action-btn edit-btn" data-type="room" data-index="{{index}}" bindtap="openEditModal">编辑</view>
            <view class="action-btn delete-btn" data-index="{{index}}" bindtap="handleDelete">删除</view>
          </view>
        </view>
        <view class="empty" wx:if="{{rooms.length === 0}}">
          <view>暂无房间数据</view>
        </view>
      </view>
    </view>

    <!-- ==================== 精油管理 ==================== -->
    <view wx:if="{{activeTab === 'oils'}}" class="section">
      <view class="section-header">
        <view class="section-title">精油列表</view>
        <view class="add-btn" bindtap="onAddOil">添加精油</view>
      </view>
      <view class="list">
        <view class="list-item {{item.status === 'disabled' ? 'disabled' : ''}}" wx:for="{{essentialOils}}" wx:key="_id">
          <view class="item-info">
            <view class="item-name">{{item.name}}</view>
            <view class="item-detail">{{item.effect}}</view>
          </view>
          <view class="item-actions">
            <view class="action-btn status-btn {{item.status === 'normal' ? 'status-normal' : 'status-disabled'}}" data-index="{{index}}" bindtap="handleToggleStatus">
              {{item.status === 'normal' ? '禁用' : '启用'}}
            </view>
            <view class="action-btn edit-btn" data-type="oil" data-index="{{index}}" bindtap="openEditModal">编辑</view>
            <view class="action-btn delete-btn" data-index="{{index}}" bindtap="handleDelete">删除</view>
          </view>
        </view>
        <view class="empty" wx:if="{{essentialOils.length === 0}}">
          <view>暂无精油数据</view>
        </view>
      </view>
    </view>

    <!-- ==================== 抽奖奖品 ==================== -->
    <view wx:if="{{activeTab === 'lottery'}}" class="section">
      <view class="section-header">
        <view class="section-title">奖品列表</view>
        <view class="add-btn" bindtap="onAddPrize">添加奖品</view>
      </view>
      <view class="list">
        <view class="list-item prize-item {{item.status === 'inactive' ? 'disabled' : ''}}" wx:for="{{prizes}}" wx:key="_id">
          <view class="prize-color" style="background-color: {{item.color}};"></view>
          <view class="item-info">
            <view class="item-name">{{item.name}}</view>
            <view class="item-detail">概率：{{item.probability}}%</view>
            <view class="item-detail">价值：{{item.value}}</view>
            <view class="item-tag" wx:if="{{item.type}}">{{item.type}}</view>
          </view>
          <view class="item-actions">
            <view class="action-btn status-btn {{item.status === 'active' ? 'status-normal' : 'status-disabled'}}" data-index="{{index}}" bindtap="handleTogglePrizeStatus">
              {{item.status === 'active' ? '禁用' : '启用'}}
            </view>
            <view class="action-btn edit-btn" data-type="prize" data-index="{{index}}" bindtap="openEditModal">编辑</view>
            <view class="action-btn delete-btn" data-index="{{index}}" bindtap="handleDeletePrize">删除</view>
          </view>
        </view>
        <view class="empty" wx:if="{{prizes.length === 0}}">
          <view>暂无奖品数据</view>
        </view>
      </view>
    </view>
  </view>

  <!-- Loading 遮罩 -->
  <view class="loading-mask" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <view class="loading-text">加载中...</view>
    </view>
  </view>

  <!-- ==================== 编辑/添加弹窗 ==================== -->
  <modal
    show="{{showModal}}"
    title="{{editingItem ? '编辑' : '添加'}}"
    show-close="{{true}}"
    bind:cancel="closeModal"
    bind:confirm="handleSave">
    <view class="modal-body">

      <!-- 通用：名称 -->
      <view class="form-item">
        <view class="form-label">名称<view class="required">*</view></view>
        <input class="form-input" value="{{formData.name}}" bindinput="onNameInput" placeholder="请输入名称" />
      </view>

      <!-- ===== 分类表单 ===== -->
      <view wx:if="{{activeTab === 'categories'}}">
        <view class="form-item">
          <view class="form-label">排序</view>
          <input class="form-input" type="number" value="{{formData.order}}" bindinput="onOrderInput" placeholder="请输入排序值" />
        </view>
      </view>

      <!-- ===== 项目表单 ===== -->
      <view wx:if="{{activeTab === 'projects'}}">
        <view class="form-item">
          <view class="form-label">副标题</view>
          <input class="form-input" value="{{formData.subtitle}}" bindinput="onSubtitleInput" placeholder="如：肩+背+腰+头 | 中式古法" />
        </view>

        <view class="form-item">
          <view class="form-label">所属分类</view>
          <picker mode="selector" range="{{projectCategories}}" range-key="name" bindchange="onCategoryChange">
            <view class="picker-val">{{formCategoryName || '请选择分类'}}</view>
          </picker>
        </view>

        <view class="form-item">
          <view class="form-label">时长（分钟）<view class="required">*</view></view>
          <input class="form-input" type="number" value="{{formData.duration}}" bindinput="onDurationInput" placeholder="请输入时长" />
        </view>

        <view class="form-item">
          <view class="form-label">价格（元）</view>
          <input class="form-input" type="digit" value="{{formData.price}}" bindinput="onPriceInput" placeholder="请输入价格" />
        </view>

        <view class="form-item">
          <view class="form-label">手工提成（元）<view class="required">*</view></view>
          <input class="form-input" type="number" value="{{formData.commission}}" bindinput="onCommissionInput" placeholder="请输入手工提成" />
        </view>

        <view class="form-item">
          <view class="form-label">是否专用精油</view>
          <view class="checkbox-wrapper" catch:tap="onIsEssentialOilOnlyChange">
            <checkbox class="form-checkbox" checked="{{formData.isEssentialOilOnly}}" />
            <view class="checkbox-label">专用精油</view>
          </view>
        </view>

        <view class="form-item">
          <view class="form-label">是否需要精油</view>
          <view class="checkbox-wrapper" catch:tap="onNeedEssentialOilChange">
            <checkbox class="form-checkbox" checked="{{formData.needEssentialOil}}" />
            <view class="checkbox-label">需要</view>
          </view>
        </view>

        <!-- 服务流程 -->
        <view class="form-item">
          <view class="form-label">服务流程</view>
          <textarea class="form-textarea" value="{{formData.serviceFlow}}" bindinput="onServiceFlowInput" placeholder="如：肩颈20分钟 + 腰背20分钟 + 手臂10分钟 + 头部10分钟" maxlength="500" auto-height />
        </view>
      </view>

      <!-- ===== 精油表单 ===== -->
      <view wx:if="{{activeTab === 'oils'}}">
        <view class="form-item">
          <view class="form-label">功效<view class="required">*</view></view>
          <input class="form-input" value="{{formData.effect}}" bindinput="onEffectInput" placeholder="请输入功效" maxlength="200" />
        </view>
      </view>

      <!-- ===== 奖品表单 ===== -->
      <view wx:if="{{activeTab === 'lottery'}}">
        <view class="form-item">
          <view class="form-label">奖品类型<view class="required">*</view></view>
          <view class="radio-group">
            <view class="radio-option {{formData.type === 'product' ? 'selected' : ''}}" bindtap="onPrizeTypeChange" data-value="product">
              <view>商品</view>
            </view>
            <view class="radio-option {{formData.type === 'discount' ? 'selected' : ''}}" bindtap="onPrizeTypeChange" data-value="discount">
              <view>折扣</view>
            </view>
            <view class="radio-option {{formData.type === 'coupon' ? 'selected' : ''}}" bindtap="onPrizeTypeChange" data-value="coupon">
              <view>优惠券</view>
            </view>
            <view class="radio-option {{formData.type === 'service' ? 'selected' : ''}}" bindtap="onPrizeTypeChange" data-value="service">
              <view>服务</view>
            </view>
          </view>
        </view>
        <view class="form-item">
          <view class="form-label">价值<view class="required">*</view></view>
          <input class="form-input" type="number" value="{{formData.value}}" bindinput="onPrizeValueInput" placeholder="请输入价值" />
        </view>
        <view class="form-item">
          <view class="form-label">中奖概率（%）<view class="required">*</view></view>
          <input class="form-input" type="digit" value="{{formData.probability}}" bindinput="onPrizeProbabilityInput" placeholder="请输入概率（0-100）" />
        </view>
        <view class="form-item">
          <view class="form-label">颜色<view class="required">*</view></view>
          <input class="form-input" value="{{formData.color}}" bindinput="onPrizeColorInput" placeholder="请输入颜色（如：#FF6B00）" />
        </view>
        <view class="form-item">
          <view class="form-label">描述</view>
          <input class="form-input" value="{{formData.description}}" bindinput="onPrizeDescriptionInput" placeholder="请输入描述（可选）" />
        </view>
      </view>

      <!-- 通用：状态 -->
      <view class="form-item">
        <view class="form-label">状态</view>
        <view class="radio-group">
          <view class="radio-option {{formData.status === 'normal' || formData.status === 'active' ? 'selected' : ''}}" bindtap="onStatusChange" data-value="{{activeTab === 'lottery' ? 'active' : 'normal'}}">
            <view>启用</view>
          </view>
          <view class="radio-option {{formData.status === 'disabled' || formData.status === 'inactive' ? 'selected' : ''}}" bindtap="onStatusChange" data-value="{{activeTab === 'lottery' ? 'inactive' : 'disabled'}}">
            <view>禁用</view>
          </view>
        </view>
      </view>
    </view>
  </modal>
</view>
