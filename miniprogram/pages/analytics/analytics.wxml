<navigation-bar title="报表分析" back="{{true}}" color="black" background="#FFF">
  <view slot="right" class="nav-btns">
    <view bindtap="onRefresh" class="nav-btn" aria-role="button" aria-label="刷新">
      <text class="nav-btn-text">刷新</text>
    </view>
  </view>
</navigation-bar>
<scroll-view class="scrollarea" scroll-y type="list">
  <view class="container">
    <view class="section">
      <view class="time-range-selector">
        <view class="time-range-options">
          <view wx:for="{{dateOptions}}" wx:key="value" class="time-range-option {{timeRangeType === item.value ? 'active' : ''}}" bindtap="onTimeRangeChange" data-value="{{item.value}}">
            <date-picker wx:if="{{item.value === 'day'}}" initialDate="{{currentDate}}" bind:change="onDateChange" />
            <text wx:else class="option-text">{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>
    <view wx:if="{{loading}}" class="loading-container">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <block wx:if="{{analyticsData && !loading}}">
      <view class="section metrics-section">
        <view class="section-title">核心数据</view>
        <view class="metrics-grid">
          <view class="metric-card">
            <view class="metric-value">{{analyticsData.keyMetrics.totalOrders}}</view>
            <view class="metric-label">总单数</view>
          </view>
          <view class="metric-card">
            <view class="metric-value">{{analyticsData.keyMetrics.totalReservations}}</view>
            <view class="metric-label">总预约数</view>
          </view>
          <view class="metric-card">
            <view class="metric-value">{{analyticsData.keyMetrics.maleAvgOrders}}</view>
            <view class="metric-label">男技师平均单量</view>
          </view>
          <view class="metric-card">
            <view class="metric-value">{{analyticsData.keyMetrics.femaleAvgOrders}}</view>
            <view class="metric-label">女技师平均单量</view>
          </view>
          <view class="metric-card highlight">
            <view class="metric-value">{{analyticsData.keyMetrics.walkInCustomers}}</view>
            <view class="metric-label">自来客数</view>
          </view>
        </view>
      </view>

      <view class="section chart-section">
        <view class="section-title">客流趋势</view>
        <view class="chart-container">
          <canvas canvas-id="customerTrendChart" class="chart-canvas"></canvas>
        </view>
      </view>
      <view class="section chart-section">
        <view class="section-title">性别趋势</view>
        <view class="chart-container">
          <canvas canvas-id="genderTrendChart" class="chart-canvas"></canvas>
        </view>
      </view>
      <view class="section chart-section" wx:if="{{timeRangeType !== 'day' && analyticsData.technicianAvgTrend}}">
        <view class="section-title">技师平均单量</view>
        <view class="chart-container">
          <canvas canvas-id="technicianAvgTrendChart" class="chart-canvas"></canvas>
        </view>
      </view>
      <view class="section chart-section">
        <view class="section-title">项目排行</view>
        <view class="chart-container">
          <canvas canvas-id="projectRankingChart" class="chart-canvas"></canvas>
        </view>
      </view>
    </block>
    <view wx:if="{{!analyticsData && !loading}}" class="empty-state">
      <text class="empty-text">暂无数据</text>
    </view>
  </view>
</scroll-view>