<navigation-bar title="顾客管理" back="{{true}}" color="black" background="#FFF">
  <view slot="right" class="nav-btns">
    <view bindtap="showAddCustomer" class="nav-btn" aria-role="button" aria-label="新增顾客">
      <text class="nav-btn-text">新增顾客</text>
    </view>
  </view>
</navigation-bar>
<view class="customers-page">
  <view class="search-bar">
    <view class="search-input-wrapper">
      <input class="search-input" type="text" placeholder="搜索顾客姓名或手机号" value="{{searchKeyword}}" bindinput="onSearchInput" bindconfirm="onSearchConfirm" />
      <view wx:if="{{searchKeyword}}" class="clear-icon" bindtap="onClearSearch">✕</view>
    </view>
    <view class="search-btn" bindtap="onSearchConfirm">搜索</view>
  </view>
  <view wx:if="{{total > 0}}" class="search-result-info">
    <text>共 {{total}} 条记录</text>
  </view>
  <view class="customer-list">
    <view wx:for="{{customerList}}" wx:key="phone" class="customer-card">
      <view class="customer-header">
        <view class="customer-info">
          <view class="customer-name">{{item.name}}{{item.gender === 'male' ? '先生' : '女士'}}</view>
          <view wx:if="{{item.phone}}" class="customer-phone">{{item.phone}}</view>
          <view class="customer-meta">
            <view wx:if="{{item.responsibleTechnician}}" class="meta-item">
              <text class="meta-label">责任技师:</text>
              <text>{{item.responsibleTechnician}}</text>
            </view>
            <view wx:if="{{item.licensePlate}}" class="meta-item">
              <text class="meta-label">车牌号:</text>
              <text>{{item.licensePlate}}</text>
            </view>
          </view>
        </view>
        <view class="action-buttons">
          <view class="action-btn open-card" catch:tap="showOpenCardModal" data-customer="{{item}}">
            开卡
          </view>
          <view class="action-btn edit" catch:tap="showEditCustomer" data-customer="{{item}}">
            编辑
          </view>
          <view class="action-btn detail" catch:tap="loadCustomerVisits" data-customer="{{item}}">
            详情
          </view>
        </view>
      </view>
      <view wx:if="{{item.remarks}}" class="customer-remarks">
        <text class="meta-label">备注:</text>
        {{item.remarks}}
      </view>
    </view>
  </view>
  <view wx:if="{{hasMore}}" class="load-more-btn" bindtap="onLoadMore">
    <text>{{loading ? '加载中...' : '加载更多'}}</text>
  </view>
  <view wx:if="{{customerList.length === 0 && !loading}}" class="empty-state">
    <view class="empty-icon">📋</view>
    <view class="empty-text">{{searchKeyword ? '未找到匹配的顾客' : '暂无顾客记录'}}</view>
  </view>
</view>
<modal show="{{showEditModal}}" title="{{modalTitle}}" bind:cancel="onModalCancel" bind:confirm="onModalConfirm">
  <view class="form-group">
    <text class="form-label">姓名</text>
    <input class="form-input" type="text" placeholder="选填" bindinput="onNameInput" value="{{formName}}" />
    <text class="form-label">手机号</text>
    <input class="form-input" type="number" placeholder="选填" maxlength="11" bindinput="onPhoneInput" value="{{formPhone}}" />
  </view>
  <view class="form-group">
    <text class="form-label">性别</text>
    <view class="gender-selector">
      <view class="gender-option {{formGender === 'male' ? 'selected' : ''}}" bindtap="onGenderChange" data-gender="male">
        <text>先生</text>
      </view>
      <view class="gender-option {{formGender === 'female' ? 'selected' : ''}}" bindtap="onGenderChange" data-gender="female">
        <text>女士</text>
      </view>
    </view>
  </view>
  <view class="form-group">
    <text class="form-label">责任技师</text>
    <view class="technician-selector">
      <label wx:for="{{technicianList}}" wx:key="_id" wx:for-item="tech" class="technician-option {{formResponsibleTechnician === tech.name ? 'selected' : ''}}" bindtap="onTechnicianSelect" data-technician="{{tech.name}}">
        <text>{{tech.name}}</text>
      </label>
    </view>
  </view>
  <view class="form-group">
    <text class="form-label">车牌号</text>
    <input class="form-input" type="text" placeholder="选填" bindinput="onLicensePlateInput" value="{{formLicensePlate}}" />
  </view>
  <view class="form-group">
    <text class="form-label">备注</text>
    <input class="form-input" type="text" placeholder="选填" bindinput="onRemarksInput" value="{{formRemarks}}" />
  </view>
</modal>
<modal show="{{showOpenCardModal}}" title="开卡" size="large" bind:cancel="onOpenCardCancel" bind:confirm="onOpenCardConfirm">
  <view class="customer-info-display">
    <view class="info-row">
      <text class="info-label">顾客:</text>
      <text class="info-value">{{selectedCustomerForCard.name}}</text>
    </view>
    <view wx:if="{{selectedCustomerForCard.phone}}" class="info-row">
      <text class="info-label">手机号:</text>
      <text class="info-value">{{selectedCustomerForCard.phone}}</text>
    </view>
  </view>
  <view class="form-group">
    <text class="form-label">选择会员卡</text>
    <view class="membership-card-selector">
      <label wx:for="{{membershipCards}}" wx:key="_id" wx:for-item="card" class="card-option {{selectedCardId === card._id ? 'selected' : ''}}" bindtap="onCardSelect" data-card="{{card}}">
        <view class="card-option-content">
          <view class="card-option-name">{{card.name}}</view>
          <view class="card-option-meta">
            <text class="meta-text">{{card.project}}</text>
            <text class="meta-text">{{card.totalTimes}}次</text>
            <text class="meta-text">¥{{card.originalPrice}}</text>
          </view>
        </view>
      </label>
    </view>
  </view>
  <view wx:if="{{selectedCardInfo}}" class="selected-card-info">
    <view class="info-row">
      <text class="info-label">会员卡:</text>
      <text class="info-value">{{selectedCardInfo.name}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">原价:</text>
      <text class="info-value">¥{{selectedCardInfo.originalPrice}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">总次数:</text>
      <text class="info-value">{{selectedCardInfo.totalTimes}}次</text>
    </view>
    <view class="info-row">
      <text class="info-label">项目:</text>
      <text class="info-value">{{selectedCardInfo.project}}</text>
    </view>
  </view>
  <view class="form-group">
    <text class="form-label">实付金额</text>
    <input class="form-input" type="digit" placeholder="请输入实付金额" bindinput="onPaidAmountInput" value="{{formPaidAmount}}" />
  </view>
  <view class="form-group">
    <view class="form-label">销售员工（可多选）</view>
    <view class="technician-selector">
      <label wx:for="{{technicianListWithSelection}}" wx:key="_id" wx:for-item="tech" class="technician-option {{tech.selected ? 'selected' : ''}}" bindtap="onSalesStaffSelect" data-staff="{{tech.name}}">
        {{tech.name}}
      </label>
    </view>
  </view>
  <view class="form-group">
    <text class="form-label">备注</text>
    <input class="form-input" placeholder="选填" bindinput="onCardRemarksInput" value="{{formCardRemarks}}" />
  </view>
</modal>
<modal show="{{showDetailModal}}" show-footer="{{false}}" title="顾客详情" bind:cancel="closeDetailModal" bind:confirm="onModalConfirm">
  <view class="detail-info">
    <view class="detail-row">
      <view class="detail-label">姓名:</view>
      <view class="detail-value">
        {{selectedCustomer.name}}{{selectedCustomer.gender === 'male' ? '先生' : (selectedCustomer.gender === 'female' ? '女士' : '')}}
      </view>
    </view>
    <view wx:if="{{selectedCustomer.phone}}" class="detail-row">
      <view class="detail-label">手机号:</view>
      <view class="detail-value">{{selectedCustomer.phone}}</view>
    </view>
    <view wx:if="{{selectedCustomer.responsibleTechnician}}" class="detail-row">
      <view class="detail-label">责任技师:</view>
      <view class="detail-value">{{selectedCustomer.responsibleTechnician}}</view>
    </view>
    <view wx:if="{{selectedCustomer.licensePlate}}" class="detail-row">
      <view class="detail-label">车牌号:</view>
      <view class="detail-value">{{selectedCustomer.licensePlate}}</view>
    </view>
    <view wx:if="{{selectedCustomer.remarks}}" class="detail-row">
      <view class="detail-label">备注:</view>
      <view class="detail-value">{{selectedCustomer.remarks}}</view>
    </view>
  </view>
  <view class="membership-cards-section">
    <view class="history-title">会员卡</view>
    <view wx:if="{{customerMemberships.length === 0}}" class="empty-history">暂无会员卡</view>
    <view wx:else class="membership-cards-list">
      <view wx:for="{{customerMemberships}}" wx:key="_id" class="membership-card-item {{item.status === 'disabled' ? 'disabled' : ''}}">
        <view class="card-header">
          <view class="card-name">{{item.cardName}}</view>
          <view class="card-status {{item.status === 'active' ? 'active' : 'disabled'}}">
            {{item.status === 'active' ? '启用' : '禁用'}}
          </view>
        </view>
        <view class="card-body">
          <view class="card-row">
            <text class="card-label">项目:</text>
            <text class="card-value">{{item.project}}</text>
          </view>
          <view class="card-row">
            <text class="card-label">剩余次数:</text>
            <text class="card-value highlight">{{item.remainingTimes}}次</text>
          </view>
          <view class="card-row">
            <text class="card-label">原价:</text>
            <text class="card-value">¥{{item.originalPrice}}</text>
          </view>
          <view class="card-row">
            <text class="card-label">实付:</text>
            <text class="card-value">¥{{item.paidAmount}}</text>
          </view>
          <view class="card-row">
            <text class="card-label">销售:</text>
            <text class="card-value" wx:for="{{item.salesStaff}}" wx:for-item="staff" wx:key="staff">
              {{staff}}
            </text>
          </view>
          <view wx:if="{{item.remarks}}" class="card-row">
            <text class="card-label">备注:</text>
            <text class="card-value">{{item.remarks}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  <view class="visit-history">
    <view class="history-title">消费记录</view>
    <view wx:if="{{visitRecords.length === 0}}" class="empty-history">暂无消费记录</view>
    <view wx:else class="history-list">
      <view wx:for="{{visitRecords}}" wx:key="_id" wx:for-index="visitIndex" class="history-item">
        <view class="history-header">
          <view class="history-date">{{item.date}}</view>
        </view>
        <view class="history-body" bindtap="goToConsultationDetail">
          <view class="history-details">
            <view class="history-detail">
              <text class="detail-label">项目:</text>
              <text>{{item.project}}</text>
            </view>
            <view class="history-detail">
              <text class="detail-label">技师:</text>
              <text>{{item.technician}}</text>
              <text wx:if="{{item.isClockIn}}">[点]</text>
            </view>
            <view class="history-detail">
              <text class="detail-label">房间:</text>
              <text>{{item.room}}</text>
            </view>
          </view>
          <view class="view-detail-hint">点击查看详情</view>
        </view>
      </view>
    </view>
  </view>
</modal>
<!-- Loading 遮罩 -->
<view class="loading-mask" wx:if="{{loading}}">
  <view class="loading-content">
    <view class="loading-spinner"></view>
    <view class="loading-text">加载中...</view>
  </view>
</view>